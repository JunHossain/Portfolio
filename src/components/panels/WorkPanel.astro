---
// Work panel: a grid of project cards. Each card opens its own detail panel
// (rendered separately in index.astro). Add a project by dropping a new .md file
// in src/content/projects/ — no change needed here.
import { getCollection } from 'astro:content';
import ProjectCard from '../ProjectCard.astro';

const projects = (await getCollection('projects')).sort((a, b) => a.data.order - b.data.order);
---

<article id="work" class="work-layout">
	<h2 class="major">Work</h2>
	<p>A few things I've built and designed. Tap one to dive in.</p>
	<div class="projects-container">
		{projects.map((project) => <ProjectCard project={project} />)}
	</div>
</article>
