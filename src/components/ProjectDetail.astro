---
// A project's dedicated detail panel. Rendered as a direct child of #main so the
// template's main.js treats it as a navigable panel (same open/close animation).
import { render } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import { asset } from '../lib/asset';
import Slider from './Slider.astro';

interface Props {
	project: CollectionEntry<'projects'>;
}

const { project } = Astro.props;
const { title, slug, headerImage, summary, tags, gallery, galleryStyle } = project.data;
const { Content } = await render(project);

const hero = headerImage ?? 'images/placeholder.svg';
---

<article id={`project-${slug}`} class="project-detail work-layout">
	<div class="project-hero">
		<img src={asset(hero)} alt={headerImage ? title : ''} />
	</div>

	<div class="project-heading">
		<h2 class="major">{title}</h2>
		{tags.length > 0 && (
			<ul class="tool-logos">
				{tags.map((t) => (
					<li>
						{t.icon ? (
							<i class={t.icon} title={t.label} aria-label={t.label}></i>
						) : (
							<img src={asset(t.img!)} alt={t.label} title={t.label} />
						)}
					</li>
				))}
			</ul>
		)}
	</div>

	{summary && <p class="summary">{summary}</p>}

	<div class="writeup">
		<Content />
	</div>

	{gallery.length > 0 &&
		(galleryStyle === 'slider' ? (
			<Slider items={gallery} />
		) : (
			<div class="gallery">
				{gallery.map((m) =>
					m.type === 'video' ? (
						<video src={asset(m.src)} controls playsinline></video>
					) : (
						<img src={asset(m.src)} alt={m.alt} loading="lazy" />
					),
				)}
			</div>
		))}

	<ul class="actions">
		<li><a href="#work" class="button small">&larr; Back to Work</a></li>
	</ul>
</article>
