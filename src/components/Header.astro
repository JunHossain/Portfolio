---
import site from '../data/site.json';

// The 4 panels. Each id must match an <article id="..."> in index.astro.
const panels = [
	{ id: 'intro', label: 'Intro' },
	{ id: 'work', label: 'Work' },
	{ id: 'contact', label: 'Contact' },
	{ id: 'friends', label: 'Friends' },
];
---

<header id="header">
	<div class="logo">
		<span class={`icon ${site.logoIcon}`}></span>
	</div>
	<div class="content">
		<div class="inner">
			<h1>{site.name}</h1>
			<p>
				{site.tagline.map((line, i) => (
					<>
						{i > 0 && <br />}
						{line}
					</>
				))}
			</p>
		</div>
	</div>
	<nav>
		<ul>
			{panels.map((p) => (
				<li><a href={`#${p.id}`}>{p.label}</a></li>
			))}
		</ul>
	</nav>
</header>
